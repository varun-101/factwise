# Postgres connection string (Neon, Vercel Postgres, Supabase, or local Postgres).
# On Vercel: add this in Project Settings -> Environment Variables.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"


# Facility-local timezone used to bucket temperatures into calendar "days".
# Must be a valid IANA timezone. Defaults to UTC if unset.
FACILITY_TIMEZONE="IST"
